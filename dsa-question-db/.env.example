# Copy to .env and fill in. Loaded via `node --env-file=.env ...` (Node >= 20.6, no dotenv needed).

# --- MongoDB target ---
MONGODB_URI=mongodb://127.0.0.1:27017
# For Atlas:
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=dsa
MONGODB_COLLECTION=questions

# --- Optional: full Striver A2Z JSON mirror ---
# If you have a JSON source for the complete A2Z sheet, point to it here and the
# builder will ingest it (expects an array of { slug|url, step, stepNo, subtopic, order }).
# Left blank => the built-in high-confidence LeetCode-slug seed is used.
STRIVER_SHEET_URL=

# --- Politeness / tuning ---
REQUEST_DELAY_MS=250
