# =============================================================================
# DSAspire — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# Real secrets must NEVER be committed — .env / .env.local are git-ignored.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/dsa-tracker
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/dsa-tracker?retryWrites=true&w=majority
MONGODB_URI="mongodb://127.0.0.1:27017/dsa-tracker"

# Optional: name of the database (falls back to the one in MONGODB_URI).
MONGODB_DB="dsa-tracker"

# Optional: only needed for LOCAL development if `mongodb+srv://` fails with
# "querySrv ECONNREFUSED" (some Windows/corporate networks refuse SRV lookups).
# MONGODB_DNS="8.8.8.8,1.1.1.1"

# --- Authentication (Auth.js v5) ----------------------------------------------
# Session signing secret: `openssl rand -hex 32`
AUTH_SECRET=""

# Comma-separated emails granted the admin role at register/login.
ADMIN_EMAILS=""
# Comma-separated emails granted SUPERADMIN (impersonation, role changes,
# deletes, progress resets). Wins over ADMIN_EMAILS.
SUPER_ADMIN_EMAILS=""

# --- Rate limiting (optional, recommended in production) -----------------------
# Upstash Redis for durable cross-instance rate limits; in-memory fallback
# is used when unset.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- WhatsApp reminders (Meta Cloud API) ---------------------------------------
# Feature is disabled until the token + phone number id are set.
# WHATSAPP_TOKEN=""            # or WHATSAPP_ACCESS_TOKEN
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_GRAPH_VERSION="v20.0"   # or GRAPH_API_VERSION
# WHATSAPP_TEMPLATE_LANG="en"

# Bearer token for the GitHub Actions scheduler calling /api/reminders/run.
# Generate with `openssl rand -hex 32` and set the SAME value as the
# REMINDER_CRON_SECRET GitHub repository secret.
REMINDER_CRON_SECRET=""
